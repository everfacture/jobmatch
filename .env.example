# JobMatch private secrets
# Copy to ~/.jobmatch/.env and fill only what you use.
# Do not commit your real ~/.jobmatch/.env file.

# Primary LLM provider — must expose an OpenAI-compatible /chat/completions endpoint.
# Examples:
#   OpenAI:     JOBMATCH_LLM_BASE_URL=https://api.openai.com/v1
#   OpenRouter: JOBMATCH_LLM_BASE_URL=https://openrouter.ai/api/v1
#   DeepSeek:   JOBMATCH_LLM_BASE_URL=https://api.deepseek.com/v1
#   Groq:       JOBMATCH_LLM_BASE_URL=https://api.groq.com/openai/v1
#   Gemini:     JOBMATCH_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   LM Studio:  JOBMATCH_LLM_BASE_URL=http://localhost:1234/v1
#   Ollama:     JOBMATCH_LLM_BASE_URL=http://localhost:11434/v1
JOBMATCH_LLM_BASE_URL=https://api.openai.com/v1
JOBMATCH_LLM_API_KEY=
JOBMATCH_LLM_MODEL=gpt-4o-mini

# Optional fallback LLM provider.
JOBMATCH_FALLBACK_LLM_BASE_URL=
JOBMATCH_FALLBACK_LLM_API_KEY=
JOBMATCH_FALLBACK_LLM_MODEL=

# Optional JSON object merged into the provider request body.
# Example for some OpenRouter routes: JOBMATCH_LLM_EXTRA_BODY={"provider":{"sort":"throughput"}}
JOBMATCH_LLM_EXTRA_BODY=
JOBMATCH_FALLBACK_LLM_EXTRA_BODY=

# Legacy aliases still work for migration: LLM_URL, LLM_API_KEY, LLM_MODEL,
# FALLBACK_LLM_URL, FALLBACK_LLM_API_KEY, FALLBACK_LLM_MODEL.

# Notification delivery.
# JOBMATCH_NOTIFIER can be: console, file, telegram
JOBMATCH_NOTIFIER=console
JOBMATCH_DIGEST_PATH=~/.jobmatch/digests/jobmatch-digest.log

# Telegram notification, optional.
# Canonical names first; legacy BOT_TOKEN/CHAT_ID/MESSAGE_THREAD_ID still work.
JOBMATCH_TELEGRAM_BOT_TOKEN=
JOBMATCH_TELEGRAM_CHAT_ID=
JOBMATCH_TELEGRAM_THREAD_ID=

# CAPTCHA solving / scraping support, optional.
CAPSOLVER_API_KEY=
PROXY=
